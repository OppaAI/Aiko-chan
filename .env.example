# ── Identity ──────────────────────────────────────────────────────────────────
# AI_NAME    : display name used in banner, chat prefix, and status bar
# OWNER_NAME : shown beside version number in banner row 2 (e.g. "Jon")
# USER_ID    : short user tag shown in banner row 2 and status bar (e.g. "OppaAI")
AI_NAME=Aiko
USER_ID=OppaAI

# LLM: Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/unsloth/Ministral-3-3B-Reasoning-2512-GGUF:UD-Q4_K_XL
OLLAMA_NUM_CTX=2048
OLLAMA_EMBED_MODEL=bge-base-en-v1.5
CONTEXT_WINDOW_TURNS=20

# ── log.py ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880   # 5MB per file
LOG_BACKUP_COUNT=3      # Keep 3 rotated backups

# Memory Layer: Mem0
MEM0_MODEL=functiongemma
FASTEMBED_CACHE_PATH=~/.cache/fastembed

# ── memorize.py — dream pass tuning ──────────────────────────────────────────
# DREAM_MERGE_THRESHOLD=0.92   # Cosine similarity cutoff for duplicate detection
# DREAM_BOOST_AMOUNT=2         # access_count bump for salient memories during dream

# ── forget.py — Ebbinghaus decay parameters ───────────────────────────────────
FORGET_HALF_LIFE_DAYS=7.0      # Days until memory strength halves
FORGET_CLEANUP_THRESHOLD=0.05  # Score floor before pruning
FORGET_ACCESS_COUNT_CAP=255    # Max access_count (prevents score inflation)
FORGET_GRACE_PERIOD_DAYS=14    # New memory protection window

# Vector DB: Qdrant (Docker default)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# WebSearch: SearXNG
SEARXNG_URL=http://localhost:8081
SEARXNG_SECRET=<secret_code>

# TTS: Kokoro TTS
KOKORO_DEVICE=1
KOKORO_VOICE=0.2*af_nicole + 0.4*af_heart + 0.4*jf_alpha
KOKORO_SPEED=1.0
KOKORO_LANG=en-us

# ASR: Faster-Whisper
WHISPER_MODEL=turbo
WHISPER_LANG=
WHISPER_DEVICE=auto
WHISPER_COMPUTE=float16
LISTEN_DEVICE=1
LISTEN_CAPTURE_RATE=48000
LISTEN_VAD_SILENCE_MS=300
LISTEN_VAD_PAD_MS=100
LISTEN_SAMPLE_RATE=16000
LISTEN_CHUNK_MS=30
LISTEN_SILENCE_DB=0.015
LISTEN_SILENCE_CHUNKS=40
LISTEN_MIN_CHUNKS=10
LISTEN_MAX_SECONDS=30