# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         Aiko-chan — Environment Config                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Identity ──────────────────────────────────────────────────────────────────
AI_NAME=Aiko                                    # Aiko's display name used in prompts and logs
USER_ID=OppaAI                                  # your user ID stored with memories in Qdrant

# ── LLM — Ollama ──────────────────────────────────────────────────────────────
# Main chat model and optional separate model for mem0 memory extraction.
# Keep MEM0_MODEL lightweight — it only summarizes/extracts facts, not chat.
# If MEM0_MODEL is unset, falls back to OLLAMA_MODEL (wastes VRAM on a big model).
# Keeping both in Ollama prevents model eviction between turns.
OLLAMA_BASE_URL=http://localhost:11434          # Ollama REST API endpoint
OLLAMA_MODEL=hf.co/unsloth/Ministral-3-3B-Instruct-2512-GGUF:UD-Q4_K_XL  # main chat LLM
MEM0_MODEL=smollm2:360m-instruct-q8_0           # tiny model for mem0 memory extraction
CONTEXT_WINDOW_TURNS=20                         # how many past turns to send as context
OLLAMA_NUM_CTX=4096                             # override Ollama context window (tokens)

# ── Vector DB — Qdrant ────────────────────────────────────────────────────────
# Qdrant stores Aiko's long-term memory vectors. Must be running before launch.
QDRANT_HOST=localhost                           # Qdrant server host
QDRANT_PORT=6333                                # Qdrant REST port (gRPC is 6334)

# ── Memory ────────────────────────────────────────────────────────────────────
# mem0 handles memory lifecycle: store, search, score, decay, merge.
# Embeddings use fastembed (ONNX, runs locally) — Ollama is NOT involved here.
# FASTEMBED_CACHE_PATH must survive reboots — /tmp is wiped on restart.
FASTEMBED_CACHE_PATH=/home/oppa-ai/.cache/fastembed  # persistent model cache (not /tmp)

# FORGET_HALF_LIFE_DAYS=7.0                     # days until a memory's retention score halves
# FORGET_CLEANUP_THRESHOLD=0.05                 # memories below this score get deleted
# FORGET_ACCESS_COUNT_CAP=255                   # max access count to prevent score inflation
# FORGET_GRACE_PERIOD_DAYS=14                   # new memories are protected from deletion for this long
# DREAM_MERGE_THRESHOLD=0.92                    # cosine similarity above which two memories merge
# DREAM_BOOST_AMOUNT=2                          # score boost applied when a memory is recalled

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls verbosity across all core modules via Python logging.
# DEBUG floods the terminal — use INFO for normal operation.
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARNING | ERROR
# LOG_MAX_BYTES=5242880                         # log file rotation size (default 5 MB)
# LOG_BACKUP_COUNT=3                            # number of rotated log files to keep

# ── TTS — MioTTS ──────────────────────────────────────────────────────────────
# MioTTS runs as an external server — start it before launching Aiko.
# Backend: Ollama serves the MioTTS GGUF model via OpenAI-compatible API.
# Frontend: run_server.py (in ~/MioTTS-Inference) wraps it as a synthesis API.
# speak.py POSTs text here and plays back the returned WAV.
MIOTTS_API_URL=http://localhost:8001            # MioTTS synthesis API (run_server.py)
MIOTTS_PRESET=jp_female                         # reference voice preset — defines Aiko's voice
# MIOTTS_DEVICE=1                               # sounddevice output index (unset = system default)

# ── STT — faster-whisper + VAD ────────────────────────────────────────────────
# faster-whisper transcribes mic audio after VAD detects end of utterance.
# WHISPER_DEVICE auto-selects CUDA if available, falls back to CPU.
# float16 requires GPU — use int8 for CPU-only machines.
WHISPER_MODEL=turbo                             # whisper model size: tiny/base/small/medium/large/turbo
WHISPER_DEVICE=auto                             # cuda | cpu | auto
WHISPER_COMPUTE=float16                         # float16 (GPU) | int8 (CPU)
WHISPER_LANG=en                                 # transcription language hint

# Microphone capture settings — adjust if audio feels clipped or too sensitive.
LISTEN_CAPTURE_RATE=48000                       # mic sample rate in Hz (device native, resampled to 16k)
#LISTEN_DEVICE=                                 # sounddevice input index (unset = system default)
LISTEN_CHUNK_MS=30                              # audio chunk size in ms for VAD processing
LISTEN_VAD_THRESHOLD=0.5                        # Silero VAD confidence threshold (0.0–1.0)
LISTEN_SILENCE_CHUNKS=20                        # consecutive silent chunks before utterance ends
LISTEN_MIN_CHUNKS=10                            # minimum speech chunks to accept (filters noise)
LISTEN_MAX_SECONDS=30                           # hard cap on recording length
LISTEN_VAD_SILENCE_MS=300                       # silence duration passed to Whisper's internal VAD
LISTEN_VAD_PAD_MS=100                           # audio padding around speech segments (ms)

# ── Web Search — SearXNG ──────────────────────────────────────────────────────
# Self-hosted SearXNG instance gives Aiko web search without leaking queries.
# Secret must match the secret_key set in SearXNG's settings.yml.
SEARXNG_URL=http://localhost:8081               # SearXNG instance URL
SEARXNG_SECRET=your_searxng_secret_here         # SearXNG secret key for authenticated requests

# ── Nightly Reflection ────────────────────────────────────────────────────────
# Aiko summarizes the day's memories and posts a journal entry to a Hugo blog.
# GITHUB_TOKEN needs repo write scope to push markdown posts.
GITHUB_TOKEN=your_github_pat_here               # GitHub PAT with repo write scope
GITHUB_REPO=OppaAI/aiko-blog                    # target repo for journal posts
GITHUB_BRANCH=main                              # branch to push to
HUGO_CONTENT_PATH=content/posts                 # path inside repo where posts are written
# REFLECT_MAX_MEMS=20                           # max memories to include in reflection
# REFLECT_TAGS=daily-reflection,ai-journal,aiko # Hugo front matter tags for posts