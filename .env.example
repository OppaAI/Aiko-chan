# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         Aiko-chan — Environment Config                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Identity ──────────────────────────────────────────────────────────────────
AI_NAME=Aiko                                    # Aiko's display name used in prompts and logs
USER_ID=OppaAI                                  # your user ID stored with memories

# ── LLM — llama.cpp ───────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:8080/v1                   # llama-server OpenAI-compatible endpoint (launch with --jinja for Ministral's chat template)
LLM_MODEL=ministral                                     # main chat LLM — must match /v1/models id/alias
REFLECT_MODEL=ministral                                  # reflection/monthly-summary LLM (defaults to LLM_MODEL if unset)
LLM_TIMEOUT=120                                         # seconds before an LLM call times out (stream + fallback)
LLM_MAX_TOKENS=280                                      # base max_tokens per chat reply (aliased as BASE_PREDICT)
BASE_PREDICT=280                                       # legacy alias for LLM_MAX_TOKENS
CONTEXT_WINDOW_TURNS=8                                  # past turns sent as context (each turn = 2 messages)
TEMPERATURE=0.80                                        # creativity — higher = more varied, lower = more focused
REPEAT_PENALTY=1.15                                     # penalise repeated tokens — prevents looping
REPEAT_LAST_N=64                                        # lookback window for repeat penalty (tokens)
TOP_P=0.92                                              # nucleus sampling — keeps output natural
TOP_K=50                                                # nucleus sampling cap — restricts next-token choices to top K candidates
REASONING_SCALE=3                                       # think+answer token multiplier on LLM_MAX_TOKENS when reasoning mode is on

# ── Memory — sqlite-vec ───────────────────────────────────────────────────────
# sqlite-vec stores Aiko's long-term memory vectors locally — no server needed.
# Embeddings use HarrierEmbedder (ONNX, runs locally) — llm-server NOT involved here.
# SQLITE_MEMORY_PATH must be on persistent storage — NOT /tmp (wiped on reboot).
SQLITE_MEMORY_PATH=/home/oppa-ai/.aiko/memory.db        # sqlite-vec DB (persistent storage)
EMBED_BASE_URL=http://localhost:8080/                   # embedding model LLM server endpoint
EMBED_MODEL=harrier                                     # embedding model for memory + semantic routing
EMBED_DIMS=640                                          # vector dimensions; must match model and memories_vec schema
EMBED_REGISTER_CUSTOM_MODEL=0                           # auto = try add_custom_model and continue if already registered; 1 = require; 0 = skip
EMBED_MODEL_FILE=model_quantized.onnx                   # ONNX filename inside custom embedder
EMBED_MODEL_DATA_FILE=model_quantized.onnx_data         # external ONNX data file inside custom embedder (blank if none)
EMBED_QUERY_INSTRUCT="Retrieve relevant memories that answer the query"  # harrier query-side instruction; documents/memories stay unprefixed
EMBED_BATCH_SIZE=64                                     # batch size for archive/migrate_embeddings.py re-embedding
EMBED_TIMEOUT_S=30                                     # seconds before embedding HTTP calls time out
EMBED_CACHE_PATH=                                      # optional local embedder cache path (blank = default)
FASTEMBED_CACHE_PATH=                                  # legacy FastEmbed cache path fallback (blank = unused)
MEMORY_EXTRACT_MIN_CHARS=80                             # skip trivial turns (greetings, "ok")
MEMORY_EXTRACT_MAX_TOKENS=128                         # max tokens for memory extraction summaries
MEMORY_EXTRACT_TIMEOUT=18                              # seconds before a memory extraction LLM call times out
EXTRACT_MODEL=                                         # optional smaller model for memory extraction (blank = LLM_MODEL)
MEMORY_RECALL_LIMIT=5                                   # memories injected into context per turn

# ── Memory Tuning (Jetson Orin Nano) ──────────────────────────────────────────
FORGET_HALF_LIFE_DAYS=7.0                     # days until retention score halves (default 7)
FORGET_ACCESS_COUNT_CAP=255                   # max access count — uint8 cap (default 255)
FORGET_BOOST_AMOUNT=2             # ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         Aiko-chan — Environment Config                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Identity ──────────────────────────────────────────────────────────────────
AI_NAME=Aiko                                    # Aiko's display name used in prompts and logs
USER_ID=OppaAI                                  # your user ID stored with memories

# ── LLM — llama.cpp ───────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:8080/v1                   # llama-server OpenAI-compatible endpoint (launch with --jinja for Ministral's chat template)
LLM_MODEL=ministral                                     # main chat LLM — must match /v1/models id/alias
REFLECT_MODEL=ministral                                  # reflection/monthly-summary LLM (defaults to LLM_MODEL if unset)
LLM_TIMEOUT=120                                         # seconds before an LLM call times out (stream + fallback)
LLM_MAX_TOKENS=280                                      # base max_tokens per chat reply (aliased as BASE_PREDICT)
BASE_PREDICT=280                                       # legacy alias for LLM_MAX_TOKENS
CONTEXT_WINDOW_TURNS=8                                  # past turns sent as context (each turn = 2 messages)
TEMPERATURE=0.80                                        # creativity — higher = more varied, lower = more focused
REPEAT_PENALTY=1.15                                     # penalise repeated tokens — prevents looping
REPEAT_LAST_N=64                                        # lookback window for repeat penalty (tokens)
TOP_P=0.92                                              # nucleus sampling — keeps output natural
TOP_K=50                                                # nucleus sampling cap — restricts next-token choices to top K candidates
REASONING_SCALE=3                                       # think+answer token multiplier on LLM_MAX_TOKENS when reasoning mode is on

# ── Memory — sqlite-vec ───────────────────────────────────────────────────────
# sqlite-vec stores Aiko's long-term memory vectors locally — no server needed.
# Embeddings use HarrierEmbedder (ONNX, runs locally) — llm-server NOT involved here.
# SQLITE_MEMORY_PATH must be on persistent storage — NOT /tmp (wiped on reboot).
SQLITE_MEMORY_PATH=/home/oppa-ai/.aiko/memory.db        # sqlite-vec DB (persistent storage)
EMBED_MODEL=harrier                 # embedding model for memory + semantic routing
EMBED_BASE_URL=http://127.0.0.1:8080
EMBED_DIMS=640                                          # vector dimensions; must match model and memories_vec schema
EMBED_REGISTER_CUSTOM_MODEL=0                           # auto = try add_custom_model and continue if already registered; 1 = require; 0 = skip
EMBED_MODEL_FILE=model_quantized.onnx                   # ONNX filename inside custom embedder
EMBED_MODEL_DATA_FILE=model_quantized.onnx_data         # external ONNX data file inside custom embedder (blank if none)
EMBED_QUERY_INSTRUCT="Retrieve relevant memories that answer the query"  # harrier query-side instruction; documents/memories stay unprefixed
EMBED_BATCH_SIZE=64                                     # batch size for archive/migrate_embeddings.py re-embedding
EMBED_TIMEOUT_S=30                                     # seconds before embedding HTTP calls time out
EMBED_CACHE_PATH=                                      # optional local embedder cache path (blank = default)
FASTEMBED_CACHE_PATH=                                  # legacy FastEmbed cache path fallback (blank = unused)
MEMORY_EXTRACT_MIN_CHARS=80                             # skip trivial turns (greetings, "ok")
MEMORY_EXTRACT_MAX_TOKENS=128                         # max tokens for memory extraction summaries
MEMORY_EXTRACT_TIMEOUT=18                              # seconds before a memory extraction LLM call times out
EXTRACT_MODEL=                                         # optional smaller model for memory extraction (blank = LLM_MODEL)
MEMORY_RECALL_LIMIT=5                                   # memories injected into context per turn

# ── Memory Tuning (Jetson Orin Nano) ──────────────────────────────────────────
FORGET_HALF_LIFE_DAYS=7.0                     # days until retention score halves (default 7)
FORGET_ACCESS_COUNT_CAP=255                   # max access count — uint8 cap (default 255)
FORGET_BOOST_AMOUNT=2                         # access_count boost for salient memories (default 2)
FORGET_CLEANUP_THRESHOLD=0.1                    # prune more aggressively — default 0.05
FORGET_GRACE_PERIOD_DAYS=31                     # keep at least one full month of detailed memories before cleanup
DREAM_MERGE_THRESHOLD=0.88                      # merge more duplicates — default 0.92
DREAM_RUN_AFTER_HOUR=0                          # daily dream/reflection can run any time after this local hour
DREAM_RUN_AFTER_MINUTE=0                        # daily dream/reflection minute within DREAM_RUN_AFTER_HOUR
DREAM_POLL_SECONDS=300                          # how often the scheduler checks for a missed daily run
DREAM_STATE_PATH=/home/oppa-ai/.aiko/dream_state.json  # stores last successful daily dream date
EXPERIENCE_LOG_PATH=/home/oppa-ai/.aiko/daily_experience.jsonl  # raw daily chat-turn JSONL used by reflections
EXPERIENCE_TURN_MAX_CHARS=4000                  # max chars saved per side of a chat turn in experience log
MONTHLY_CONSOLIDATION_ENABLED=1                 # consolidate older memories into a pinned monthly summary
MONTHLY_CONSOLIDATION_SOURCE=experience         # experience = summarize raw daily JSONL turns; memory = summarize vector facts
MONTHLY_CONSOLIDATION_KEEP_MONTHS=1             # keep the most recent full month as detailed memories
MONTHLY_CONSOLIDATION_CHUNK_TURNS=40            # experience turns per monthly summary chunk
MONTHLY_CONSOLIDATION_CHUNK_MEMS=25             # memory facts per fallback summary chunk
MONTHLY_CONSOLIDATION_MAX_INPUT_CHARS=6000      # max source chars per monthly consolidation LLM request
MONTHLY_CONSOLIDATION_DELETE_ORIGINALS=1        # delete unpinned detailed memories after pinned monthly summary is saved
MONTHLY_CONSOLIDATION_DELETE_DAILY_SUMMARIES=1  # replace older pinned daily summaries with the monthly pinned summary
MONTHLY_CONSOLIDATION_MIN_MEMS=5                # skip memory fallback months with fewer memories than this
MONTHLY_CONSOLIDATION_LLM_TIMEOUT=120           # seconds before monthly summary LLM calls time out
MONTHLY_CONSOLIDATION_STATE_PATH=/home/oppa-ai/.aiko/monthly_consolidation_state.json
DREAM_BOOST_AMOUNT=2                            # access_count boost applied to memories promoted during the dream/reflection cycle

# ── Async Memory Write Timing ────────────────────────────────────────────────
# Memory extraction shares the same LLM as chat unless specified — these control when the
# background writer is allowed to use it without competing with you.
## EXTRACT_MODEL=smollm2:135m-instruct-q8_0     # separate extraction model (unset = use LLM_MODEL)
MEMORY_WRITE_IDLE_GRACE=3.0                     # seconds of idle chat required before memory write proceeds
MEMORY_WRITE_MAX_WAIT=45.0                      # max seconds memory writer waits before forcing the write anyway
MEMORY_SEARCH_CACHE_SIZE=128                    # max number of query results cached in memory search LRU cache
MEMORY_SEARCH_CACHE_TTL=20.0                    # seconds before a cached memory search result expires
MEMORY_RANK_RECENCY_WEIGHT=0.004                # small retrieval boost for recent memories after semantic/FTS RRF
MEMORY_RANK_RECENCY_HALF_LIFE_DAYS=30           # recency boost halves every N days
MEMORY_RANK_ACCESS_WEIGHT=0.002                 # small boost for frequently recalled memories
MEMORY_RANK_PINNED_WEIGHT=0.002                 # small boost for pinned/special memories
MEMORY_CONTEXT_FACT_CHARS=220                   # max characters per individual memory fact injected into context
MEMORY_CONTEXT_TOTAL_CHARS=1200                 # total character budget for all memory facts injected per turn
MEMORY_LIFECYCLE_BATCH_SIZE=500                 # memories processed per batch during decay/cleanup lifecycle runs
WRITE_DEDUP_THRESHOLD=0.95                      # skip memory write if a near-duplicate already exists above this similarity score

# ── WebUI / VRM ───────────────────────────────────────────────────────────────
HTTP_PORT=8787                                  # browser WebUI HTTP port
WS_PORT=8765                                    # browser WebSocket bridge port
NO_BROWSER=0                                    # 1 = do not auto-open browser on launch
KARAOKE_TEXT=0                                  # 1 = WebUI/TUI text appears paced by TTS audio; 0 = raw LLM token stream
WEBUI_LOCAL_PLAYBACK=1                          # 1 = browser + local speaker; 0 = browser-only TTS playback
STREAM_DRAW_INTERVAL=0.05                       # seconds between streamed-token redraws in the active UI
VRM_PATH=static/Aiko.vrm                        # path to the browser avatar VRM file
EMIT_DELAY=0.012                                # delay (sec) between word emits to TUI callback — sync with TTS pacing
LATENCY_LOG=1                                   # log per-turn timing: voice-end→submit, first token, TTS start, full turn

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG floods the terminal — use INFO for normal operation.
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARNING | ERROR
DB_SIZE_TTL=1.0                                 # seconds to cache memory DB size in the vitals bar
LOG_MAX_BYTES=5242880                           # log file rotation size (default 5 MB)
LOG_BACKUP_COUNT=3                              # number of rotated log files to keep

# ── TTS — MioTTS ──────────────────────────────────────────────────────────────
# MioTTS runs as an external server — start it before launching Aiko.
# Backend: OpenAI-compatible local server serves the MioTTS GGUF model.
# Frontend: run_server.py (in ~/MioTTS-Inference) wraps it as a synthesis API.
# speak.py POSTs text here and plays back the returned WAV.
MIOTTS_API_URL=http://localhost:8001            # MioTTS synthesis API (run_server.py)
MIOTTS_MODEL=MioTTS-0.4B-Q4_K_M                 # TTS model served by MioTTS
MIOTTS_PRESET=jp_female                         # reference voice preset — defines Aiko's voice
MIOTTS_DEVICE=-1                                # sounddevice output index (unset = system default)

# ── ASR — SenseVoice via sherpa-onnx + Silero VAD ────────────────────────────────
# SenseVoice ASR transcribes mic audio after Silero VAD detects the utterance.
ASR_DEVICE=cuda                                 # sherpa-onnx execution provider: cpu (cuda EP unavailable on JP7.2)
ASR_LANGUAGE=auto                               # transcript language: auto, en, ja, zh, ko, yue, nospeech
ASR_NUM_THREADS=4                               # CPU inference threads for SenseVoice
ASR_MODEL=csukuangfj/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17  # model.int8.onnx + tokens.txt fetched on first boot

# Microphone capture settings — adjust if audio feels clipped or too sensitive.
LISTEN_VAD_SILENCE_MS=300                       # silence duration before ending an utterance
LISTEN_VAD_PAD_MS=100                           # audio padding around speech segments (ms)
LISTEN_CHUNK_MS=30                              # audio chunk size in ms for VAD processing
LISTEN_VAD_THRESHOLD=0.5                        # Silero VAD confidence threshold (0.0–1.0)
LISTEN_SILENCE_CHUNKS=66                        # consecutive silent chunks before utterance ends
LISTEN_MIN_CHUNKS=10                            # minimum speech chunks to accept (filters noise)
LISTEN_MAX_SECONDS=30                           # hard cap on recording length
LISTEN_CAPTURE_RATE=48000                       # mic sample rate in Hz (device native, resampled to 16k)
LISTEN_DEVICE=                                  # sounddevice input index (unset = system default)

# ── Speaker Verification — sherpa-onnx SpeakerEmbeddingExtractor ─────────────
# Single-enrollment 1:1 voice check (not multi-speaker ID) — verifies the
# buffered utterance against one enrolled voice, run in parallel with
# transcription in listen.py. Never blocks ASR; attaches verified=True/False/
# None to listen()'s returned info dict. Run enroll_speaker.py once before
# enabling. Get embedding models from:
# https://github.com/k2-fsa/sherpa-onnx/releases/tag/speaker-recongition-models
SPEAKER_VERIFY_ENABLED=1                        # 0 = disabled, verified always None
SPEAKER_MODEL_PATH=models/3dspeaker_speech_eres2net_base_sv_en_voxceleb_16k.onnx  # embedding model .onnx
SPEAKER_VERIFY_THRESHOLD=0.5                    # cosine similarity cutoff for a match (tune after testing)
SPEAKER_NUM_THREADS=1                           # embedding extraction is cheap — no need to raise

BARGE_IN_THRESHOLD=0.65                         # Silero speech probability to count as a barge-in chunk
BARGE_IN_CONFIRM_CHUNKS=2                       # consecutive chunks above threshold before barge-in fires
BARGE_IN_COOLDOWN_MS=800                        # ms before barge-in event can fire again after triggering
BARGE_IN_ALWAYS_ON=0                            # 1 = monitor even outside TTS playback; 0 = arm on speak only

# ── Web Search — SearXNG ──────────────────────────────────────────────────────
# Self-hosted SearXNG instance gives Aiko web search without leaking queries.
# Secret must match the secret_key set in SearXNG's settings.yml.
SEARXNG_URL=http://localhost:8081               # SearXNG instance URL
SEARXNG_SECRET=<SearXNG Secret key>             # SearXNG secret key for authenticated requests
SEARCH_SEMANTIC_THRESHOLD=0.70                  # cosine-similarity cutoff to trigger web search in chat mode (lower = more searches, higher = safer fallback)

# ── Nightly Reflection ────────────────────────────────────────────────────────
# Aiko summarizes the day's memories and posts a journal entry to a Hugo blog.
# GITHUB_TOKEN needs repo write scope to push markdown posts.
GITHUB_TOKEN=<Your GitHub token>                # GitHub PAT with repo write scope
GITHUB_REPO=OppaAI/aiko-blog                    # target repo for journal posts
GITHUB_BRANCH=main                              # branch to push to
HUGO_CONTENT_PATH=content/posts                 # path inside repo where posts are written
HUGO_IMAGES_PATH=static/images                  # path inside repo where generated reflection images are written
SOUL_PATH=persona/soul.md                       # personality/soul prompt used by reflection
IMAGEGEN_URL=https://oppa-ai-org--aiko-imagegen-fastapi-app.modal.run  # image generation API endpoint
HF_HUB_OFFLINE=0                                # set 1 on AuRoRA for field use
HF_TOKEN=<Your HuggingFace token>               # HuggingFace token for updating AI models
REFERENCE_IMAGE=/home/oppa-ai/Aiko-chan/assets/Aiko-chan.png   # path or URL to Aiko's reference image (used in blog posts / reflection)
USER_REFERENCE_IMAGE=/home/oppa-ai/Aiko-chan/assets/OppaAI.png # path or URL to oppa's reference image (used in blog posts / reflection)

REFLECT_MAX_MEMS=100                            # max memories to include in reflection
REFLECT_TAGS=daily-reflection,ai-journal,aiko   # Hugo front matter tags for posts

# ── Weekly Social Memory Post ─────────────────────────────────────────────────
# Aiko's non-agentic weekly "memory postcard". By default this only creates a
# local review bundle under workspace/social/weekly and never posts automatically.
AIKO_WEEKLY_SOCIAL_ENABLED=0                    # 1 = scheduler creates weekly drafts
AIKO_WEEKLY_SOCIAL_AUTODRAFT=1                  # 1 = create draft/image bundle when weekly job fires
AIKO_WEEKLY_SOCIAL_AUTOPOST=0                   # 1 = post automatically after drafting (not recommended at first)
AIKO_WEEKLY_SOCIAL_WEEKDAY=sunday               # weekday when the weekly draft job runs
AIKO_WEEKLY_SOCIAL_TIME=18:00                   # local wall-clock time for the weekly draft job
AIKO_WEEKLY_SOCIAL_PROVIDERS=x                  # comma-separated: x,threads
AIKO_WEEKLY_SOCIAL_MAX_CHARS=260                # short enough for X while leaving room for links/metadata
AIKO_SOCIAL_ROOT=workspace/social/weekly        # local review bundles live here

# AIsa Twitter/X posting. Connect Aiko's X account through AIsa OAuth first,
# then set the API key and exact post endpoint from the AIsa skill/API docs.
AISA_API_KEY=                                   # AIsa API key
AISA_TWITTER_POST_URL=                          # full AIsa endpoint URL for posting a tweet
AIKO_X_ACCOUNT_USERNAME=                        # optional sanity label for the connected X account

# Meta Threads posting. Meta's official Threads API has no published per-call
# fee, but requires a Meta app, Threads permissions, and a valid user token.
# Image posts require a public image_url; local draft images are not enough.
THREADS_USER_ID=                                # Threads user id from Meta/Threads API
THREADS_ACCESS_TOKEN=                           # long-lived Threads user access token
THREADS_API_BASE=https://graph.threads.net/v1.0 # official Threads API base URL
THREADS_PUBLISH_DELAY_SECONDS=5                 # wait between container create and publish
AIKO_WEEKLY_SOCIAL_IMAGE_URL=                   # optional public URL for the generated weekly image before Threads posting

# ── Intent Routing (chat vs agentic/search) ─────────────────────────────────
# ROUTE_MODE=semantic is fastest: one local embedding and cached example vectors.
# ROUTE_MODE=llm is slower but can resolve context/pronouns through ROUTER_MODEL.
ROUTE_ENABLED=1                                 # 0 = always chat, never auto-route to agentic/search
ROUTE_MODE=semantic                             # semantic | semantic_only | llm | chat
ROUTER_MODEL=smollm                             # LLM used only for routing when ROUTE_MODE=llm or semantic fallback; can be a tiny model
ROUTE_SEMANTIC_THRESHOLD=0.70                   # higher = fewer agentic triggers; lower = more eager agentic mode
ROUTE_MIN_GAP=0.025                             # best-vs-second semantic score gap required before routing agentic
ROUTE_TOOL_MIN_GAP=0.015                        # smaller gap after a task is already confirmed; fallback to LLM below this
ROUTE_SEARCH_MIN_GAP=0.010                      # web-search score gap required after chat is confirmed
ROUTE_LABEL_TOP_K=3                             # average each label strongest N examples instead of trusting one close vector

# ── Scheduling ──────────────────────────────────────────────────────────────
TIMEZONE=America/Vancouver                      # IANA tz name used for scheduling/reminders (e.g. America/Vancouver, UTC)
WORKSPACE_ROOT=workspace                        # Root folder for notes, schedule.json, reminders.json, and saved files
SCHEDULE_PATH=workspace/schedule.json           # Path to the persistent scheduled-jobs file
REMINDERS_PATH=workspace/reminders.json         # legacy reminders file migrated into scheduled jobs
SCHEDULE_POLL_SECONDS=15                        # How often (seconds) the scheduler checks for due jobs
DAILY_JOB_HOUR=0                                # local hour for daily reflection job
DAILY_JOB_MINUTE=0                              # local minute for daily reflection job
MONTHLY_JOB_HOUR=0                              # local hour for monthly consolidation job
MONTHLY_JOB_MINUTE=5                            # local minute for monthly consolidation job

# ── Agent ───────────────────────────────────────────────────────────────────
MAX_AGENT_ITER=12                               # Max tool-call steps allowed per task
AGENT_MAX_TOKENS=512                            # Max output tokens per agent step (separate from chat)
AGENT_NOTE_MAX_CHARS=1500                       # max chars from notes/files included in an agent step
AGENT_TOOL_RESULT_MAX_CHARS=3000                # max chars retained from a single tool result
AGENT_MEMORY_DRAIN_TIMEOUT=0.25                 # Seconds to wait for memory queue before agent starts
MEMORY_AGENT_DRAIN_TIMEOUT=0.25                 # legacy alias for AGENT_MEMORY_DRAIN_TIMEOUT
AGENT_MEMORY_RECALL_LIMIT=2                     # Memories injected into agent context (keep low)
SEARXNG_MAX_RESULTS=3                           # Search results returned per query (less = fewer tokens)
AGENT_VERIFY_FINAL=1                            # Whether to verify the final answer before returning it
AGENT_VERIFY_LLM=0                              # Whether verification uses an LLM call
AGENT_MAX_FINAL_REPAIRS=1                       # Max retries to repair a bad final answer
AGENT_VERIFY_MIN_SCORE=0.70                     # LLM verifier scores below this fail even if pass=true
AGENT_TOOL_RETRY_BACKOFF=0.2                    # Delay (seconds) before retrying a failed tool call
AGENT_WEB_TOOL_ATTEMPTS=2                       # retry attempts for web-backed agent tools
AGENT_LOCAL_TOOL_ATTEMPTS=1                     # retry attempts for local agent tools
# ── Tools ───────────────────────────────────────────────────────────────────
MAX_WRITE_CHARS=20000                           # Max characters allowed when saving a note/draft to disk
MAX_READ_CHARS=12000                            # Max characters returned when reading a workspace file back

# ── Idle Learner ──────────────────────────────────────────────────────────────
IDLE_LEARN_SECONDS=1800                         # seconds of inactivity before Aiko self-researches a past topic
