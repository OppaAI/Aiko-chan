# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         Aiko-chan — Environment Config                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Identity ──────────────────────────────────────────────────────────────────
AI_NAME=Aiko
USER_ID=OppaAI

# ── LLM — Ollama ──────────────────────────────────────────────────────────────
# MEM0_MODEL is optional — if unset falls back to OLLAMA_MODEL.
# Keep them the same to avoid Ollama evicting models from VRAM.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/unsloth/Ministral-3-3B-Reasoning-2512-GGUF:UD-Q4_K_XL
MEM0_MODEL=
CONTEXT_WINDOW_TURNS=20
# OLLAMA_NUM_CTX=2048

# ── Vector DB — Qdrant ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Memory ────────────────────────────────────────────────────────────────────
# Embeddings handled by fastembed (ONNX, local) — no Ollama involvement.
# FORGET_HALF_LIFE_DAYS=7.0
# FORGET_CLEANUP_THRESHOLD=0.05
# FORGET_ACCESS_COUNT_CAP=255
# FORGET_GRACE_PERIOD_DAYS=14
# DREAM_MERGE_THRESHOLD=0.92
# DREAM_BOOST_AMOUNT=2

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=3

# ── TTS — Kokoro ──────────────────────────────────────────────────────────────
# Voice blend weights must sum to 1.0
MIOTTS_API_URL=http://localhost:8001
MIOTTS_PRESET=jp_female
#KOKORO_DEVICE=1
#KOKORO_VOICE=0.2*af_nicole + 0.4*af_heart + 0.4*jf_alpha
#KOKORO_SPEED=1.0
#KOKORO_LANG=en-us

# ── STT — faster-whisper + Silero VAD ─────────────────────────────────────────
# WHISPER_DEVICE: cuda, cpu, or auto
# WHISPER_COMPUTE: float16 for GPU, int8 for CPU
WHISPER_MODEL=turbo
WHISPER_DEVICE=auto
WHISPER_COMPUTE=float16
WHISPER_LANG=en

LISTEN_CAPTURE_RATE=48000
LISTEN_DEVICE=
LISTEN_CHUNK_MS=30
LISTEN_VAD_THRESHOLD=0.5
LISTEN_SILENCE_CHUNKS=40
LISTEN_MIN_CHUNKS=10
LISTEN_MAX_SECONDS=30
LISTEN_VAD_SILENCE_MS=300
LISTEN_VAD_PAD_MS=100

# ── Web Search — SearXNG ──────────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8081
SEARXNG_SECRET=<secret_code>

# ── Nightly Reflection ────────────────────────────────────────────────────────
# GITHUB_TOKEN requires repo write scope.
GITHUB_TOKEN=your_pat_here
GITHUB_REPO=OppaAI/oppaai.github.io
GITHUB_BRANCH=main
HUGO_CONTENT_PATH=content/posts
# REFLECT_MAX_MEMS=20
# REFLECT_TAGS=daily-reflection,ai-journal,aiko
