# Aiko private environment values
#
# Keep only private tokens/keys here. Non-secret runtime settings live in config/*.yaml.
#
# AISA_API_KEY:
#   API key for the AIsa Twitter/X relay used by core/social.py.
#   Get it from your AIsa account/dashboard for the relay service you use.
#
# GITHUB_TOKEN:
#   GitHub personal access token used by core/reflect.py to publish Hugo posts.
#   Create one in GitHub Developer settings with access to the target blog repo.
#
# HF_TOKEN:
#   Hugging Face token for private/gated model downloads or model upload/update flows.
#   Create one at huggingface.co/settings/tokens when needed.
#
# SEARXNG_SECRET:
#   Secret that matches your SearXNG instance configuration.
#   Copy it from searxng/settings.yml or the deployed SearXNG settings file.
#
# THREADS_USER_ID:
#   Numeric Meta Threads user ID that THREADS_ACCESS_TOKEN authenticates as.
#   Used by core/social.py alongside the access token for the two-step
#   container/publish flow. Find it via the Threads API /me endpoint or your
#   Meta app's Graph API Explorer while testing the token below.
#
# THREADS_ACCESS_TOKEN:
#   Long-lived Meta Threads user access token used by core/social.py.
#   Generate through your Meta app / Threads API authorization flow, then refresh before expiry.
#
# IMGBB_API_KEY:
#   ImgBB API key used by core/social.py to host generated draft images for Threads.
#   Create one in your ImgBB account API settings; Threads requires a public image URL.
#
AISA_API_KEY=<Your AISA key>
GITHUB_TOKEN=<Your GitHub token>
HF_TOKEN=<Your HuggingFace token>
IMGBB_API_KEY=<Your ImgBB API key>
SEARXNG_SECRET=<SearXNG Secret key>
THREADS_USER_ID=<Threads User ID>
THREADS_ACCESS_TOKEN=<Threads Access Token>

# ALLOWED_GITHUB_USERS:
#   Owner/contributor allowlist checked in auth.py after GitHub OAuth callback.
#   Comma-separated GitHub usernames. Only listed users (or, if
#   CONTRIBUTORS_ENABLED=true, confirmed repo contributors) get a session
#   cookie — everyone else who successfully logs in via GitHub still gets a 403.
# ALLOWED_PATREON_USERS:
#   Owner allowlist for Patreon login, checked in auth.py before the
#   active-patron check. Comma-separated numeric Patreon user IDs — get yours
#   by logging in once, checking the 403 error, or logging user_id in
#   patreon_callback temporarily. Users on this list skip the patron_status
#   check entirely (so you don't have to pay yourself).
ALLOWED_GITHUB_USERS=<Your Github Username>
ALLOWED_PATREON_USERS=<Your Patreon numeric user ID>

# CONTRIBUTORS_ENABLED / GITHUB_REPO:
#   When CONTRIBUTORS_ENABLED=true, GitHub login also succeeds for anyone with
#   a commit on GITHUB_REPO (checked live against the GitHub API), not just
#   ALLOWED_GITHUB_USERS. Leave false until you're ready to open access up.
CONTRIBUTORS_ENABLED=false
GITHUB_REPO=OppaAI/Aiko-chan

# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET:
#   OAuth app credentials from GitHub Developer settings > OAuth Apps.
#   Authorization callback URL must be set there to match REDIRECT_BASE below,
#   e.g. https://aiko.ide-chroma.ts.net/auth/github/callback.
#
GITHUB_CLIENT_ID=<Your Github Client ID>
GITHUB_CLIENT_SECRET=<Your Github Client Secret>

# PATREON_CLIENT_ID / PATREON_CLIENT_SECRET:
#   OAuth app credentials from patreon.com/portal/registration/register-clients.
#   Redirect URI there must match REDIRECT_BASE/auth/patreon/callback.
#
# PATREON_CREATOR_ACCESS_TOKEN:
#   Creator access token from the same Patreon client registration page,
#   used by auth.py to look up campaign membership/patron status.
#
# PATREON_CAMPAIGN_ID:
#   Your numeric Patreon campaign ID, found on your creator dashboard URL.
#
PATREON_CLIENT_ID=<Your Patreon Client ID>
PATREON_CLIENT_SECRET=<Your Patreon Client Secret>
PATREON_CREATOR_ACCESS_TOKEN=<Your Patreon Creator Access Token>
PATREON_CAMPAIGN_ID=<Your Patreon Campaign ID>

# REDIRECT_BASE:
#   Base URL OAuth providers redirect back to after login. Must exactly match
#   what's registered in each provider's OAuth app settings (scheme+host+port).
#   Update this (and the provider dashboards) when you move hosts.
#
# SECRET_KEY:
#   Signing key for session cookies (auth.py uses itsdangerous to sign the
#   session payload directly into the cookie — no server-side session store,
#   so sessions survive process restarts/Jetson reboots). Generate once with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
#   Treat like a password — rotating it instantly logs everyone out.
#
REDIRECT_BASE=https://aiko.ide-chroma.ts.net
SECRET_KEY=<Generate a key — see command above>

# SQLITE_ENCRYPTION / DATA_KEY_SECRET:
#   Optional memory DB encryption. Requires a SQLCipher-capable Python driver
#   in the runtime image. Generate the data key once with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(64))"
#   Store only in .env / Modal secrets / secret manager, never in YAML committed to git.
SQLITE_ENCRYPTION=0
DATA_KEY_SECRET="<Generate a separate data encryption secret>"

# TERMS_STORE_PATH (optional):
#   Where auth.py persists which users have accepted which TERMS_VERSION.
#   Defaults to ./terms_acceptance.json if unset.
TERMS_STORE_PATH=terms_acceptance.json
